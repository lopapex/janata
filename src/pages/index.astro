---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParteGrid from '../components/ParteGrid.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { loadContent } from '../lib/content';

const content = await loadContent();
const s = content.settings;
---
<BaseLayout title={content.seo.title} description={content.seo.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Pohřební služba v Žamberku</p>
        <h1>{s.heroTitle}</h1>
        <p class="hero-lead">{s.heroText}</p>
        <div class="button-row">
          <a class="button button-primary" href={`tel:${s.phoneHref}`}>Zavolat</a>
          <a class="button button-secondary" href="#postup">Co dělat při úmrtí</a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/hero-janata.webp" alt="Klidná cesta mezi stromy na místním hřbitově" width="1536" height="1024" fetchpriority="high" />
      </div>
    </div>
  </section>

  <section class="reassurance" aria-label="Základní informace">
    <div class="container reassurance-grid">
      <p><strong>Osobní přístup</strong><span>Vysvětlíme vše srozumitelně a bez spěchu.</span></p>
      <p><strong>Žamberk a okolí</strong><span>Najdete nás přímo pod žamberskou radnicí.</span></p>
      <p><strong>Pomoc s vyřízením</strong><span>Provedeme vás jednotlivými kroky rozloučení.</span></p>
    </div>
  </section>

  <section id="postup" class="section process-section">
    <div class="container process-grid">
      <div class="process-intro">
        <SectionHeading title="Co dělat, když někdo zemře" text="V první chvíli stačí vyřešit jen několik nezbytných kroků. S ostatním vám pomůžeme osobně." />
        <img src="/images/priprava-obradu.webp" alt="Bílé květiny a připravený list papíru" width="1448" height="1088" loading="lazy" />
      </div>
      <ol class="process-list">
        <li><span>Úmrtí doma</span><p>Zavolejte praktického lékaře nebo zdravotnickou záchrannou službu. Lékař vystaví List o prohlídce zemřelého.</p></li>
        <li><span>Úmrtí v zařízení</span><p>Nemocnice nebo sociální zařízení vás bude informovat a sdělí vám další postup.</p></li>
        <li><span>Kontaktujte nás</span><p>Domluvíme osobní schůzku a řekneme vám, které doklady a oblečení je vhodné přinést.</p></li>
        <li><span>Společně vše připravíme</span><p>Probereme podobu rozloučení, termín, parte, květiny, hudbu a ostatní přání rodiny.</p></li>
      </ol>
    </div>
  </section>

  <section id="sluzby" class="section services-section">
    <div class="container">
      <SectionHeading eyebrow="Naše pomoc" title="Zařídíme potřebné kroky" text="Rozsah služeb vždy přizpůsobíme přání rodiny a charakteru posledního rozloučení." />
      <div class="services-grid">
        {content.services.map((service, index) => (
          <article class:list={['service-item', index === 0 && 'service-featured']}>
            <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section about-section">
    <div class="container about-grid">
      <div class="about-image"><img src="/images/obradni-sin.webp" alt="Důstojný vstup do obřadní budovy obklopený zelení" width="1536" height="1024" loading="lazy" /></div>
      <div class="about-copy">
        <SectionHeading title={s.aboutTitle} text={s.aboutText} />
        <blockquote>„Profesionální přístup, jednání na úrovni. Poradí a pomohou.“<cite>Veřejné hodnocení zákazníka</cite></blockquote>
        <a class="text-link" href="#kontakt">Kontaktní údaje</a>
      </div>
    </div>
  </section>

  <section class="section parte-preview">
    <div class="container">
      <SectionHeading title="Smuteční oznámení" text="Aktuální parte zveřejněná se souhlasem pozůstalé rodiny na webu města Žamberk." />
      <ParteGrid limit={3} />
      <div class="section-action"><a class="button button-secondary" href="/parte/">Všechna parte</a></div>
    </div>
  </section>

  <section class="section gallery-section">
    <div class="container">
      <SectionHeading title="Prostor pro důstojné rozloučení" />
      <div class="gallery-grid">
        {content.gallery.map((item, index) => <img src={item.src} alt={item.alt} loading="lazy" class:list={[index === 0 && 'gallery-wide']} />)}
      </div>
    </div>
  </section>

  <section id="kontakt" class="section contact-section">
    <div class="container contact-grid">
      <div class="contact-details">
        <SectionHeading eyebrow="Kontakt" title="Ozvěte se nám" text="Zavolejte a domluvíme další postup nebo osobní návštěvu v kanceláři." />
        <a class="contact-phone" href={`tel:${s.phoneHref}`}>{s.phone}</a>
        <address>{s.owner}<br />{s.address}</address>
        <p>IČO {s.ico}</p>
        <a class="button button-primary" href="https://mapy.com/cs/zakladni?source=coor&id=16.4646499%2C50.0881857&x=16.4646499&y=50.0881857&z=18" target="_blank" rel="noopener noreferrer">Zobrazit mapu</a>
      </div>
      <div class="map-shell contact-map-inline">
        <iframe title="Mapa kanceláře Pohřební služby Janata v Žamberku" src="https://frame.mapy.cz/cs/zakladni?source=coor&amp;id=16.4646499%2C50.0881857&amp;x=16.4646499&amp;y=50.0881857&amp;z=18" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
      </div>
    </div>
  </section>

  <aside class="draft-notice"><div class="container">{s.notice}</div></aside>
</BaseLayout>
